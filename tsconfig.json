{
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "moduleResolution": "bundler",
        "module": "esnext",
        "target": "esnext",
        "skipLibCheck": true,
        "paths": {
            "@css/*": ["./styles/*"]
        }
    },
    "include": ["source/**/*", "styles/**/*", "tests/**/*"]
}
